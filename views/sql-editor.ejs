<!DOCTYPE html>
<html>
<head>
  <title>SQL Editor - <%= filename %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="dashboard-header">
    <h1>🗄️ SQL Editor — <%= filename %></h1>
    <div class="header-user">
      <a href="/admin" class="logout-link">← Admin</a>
      <a href="/logout" class="logout-link">Logout</a>
    </div>
  </header>
  <div class="container">
    <div class="section-card">
      <div class="section-card-header">Editing: <%= filename %></div>
      <div class="section-card-body">
        <% if (saved) { %>
          <div class="success-msg">✅ File saved successfully!</div>
        <% } %>
        <form action="/admin/sql/<%= filename %>" method="POST">
          <textarea name="content" class="sql-textarea"><%= content %></textarea>
          <br>
          <button type="submit" class="save-btn">💾 Save File</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>